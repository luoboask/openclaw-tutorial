# OpenClaw 网站自动巡检 Cron 配置
# 添加到系统 crontab: crontab -e

# 每天 09:00 执行巡检维护
0 9 * * * /Users/openmilo/clawall/claw-team/claw-admin/scripts/daily-maintenance.sh >> /Users/openmilo/clawall/claw-team/claw-admin/logs/cron.log 2>&1

# 每小时检查网站是否运行（如果 09:00 的重启失败）
0 * * * * curl -s http://localhost:3000/ > /dev/null || /Users/openmilo/clawall/claw-team/claw-admin/scripts/daily-maintenance.sh >> /Users/openmilo/clawall/claw-team/claw-admin/logs/cron.log 2>&1

# 每周日 03:00 深度清理
0 3 * * 0 /Users/openmilo/clawall/claw-team/claw-admin/scripts/weekly-cleanup.sh >> /Users/openmilo/clawall/claw-team/claw-admin/logs/cleanup.log 2>&1
